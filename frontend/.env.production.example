# Скопируйте в .env.production перед vite build (или задайте в CI).
# Нужно только если фронт открывается с другого origin, чем публичный URL API/картинок.
# Один домен + nginx проксирует /api и /uploads — переменную можно не задавать:
# в рантайме подставится window.location.origin (уже https после вашего SSL).

# VITE_PUBLIC_APP_URL=https://pim.giper.fm.postobot.online

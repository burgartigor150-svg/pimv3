# Скопируйте в .env и заполните. Файл .env не коммитьте.

DATABASE_URL=postgresql+asyncpg://pim_user:CHANGE_ME@localhost:5440/pim_db
SQLALCHEMY_ECHO=false

# После git pull с новыми миграциями: из каталога backend выполните `alembic upgrade head`
# (без PYTHONPATH — путь к пакету backend настраивается в alembic/env.py).

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Публичный URL API, который видит интернет (схема https в проде, без завершающего /).
# Для выгрузки в Мегамаркет: только https и публичный хост — иначе в JSON не подставляется прокси к Ozon
# (в теле нельзя 127.0.0.1 — у edge MM часто 403). Локально фото в card/save идут прямыми ссылками на CDN.
PUBLIC_API_BASE_URL=http://127.0.0.1:4877
# Пример для продакшена с доменом и SSL (подставьте свой хост):
# PUBLIC_API_BASE_URL=https://pim.giper.fm.postobot.online

# Мегамаркет: fallback locationId склада, если в подключении не задан warehouse_id (price/*, stock/*)
MEGAMARKET_DEFAULT_LOCATION_ID=

# Опционально: исходящий прокси только для запросов к Мегамаркету (если по политике нужен другой IP).
# MEGAMARKET_HTTPS_PROXY=http://user:pass@host:3128
# Либо общий HTTPS_PROXY для процесса uvicorn.
# Если нужно повторить User-Agent другого клиента (curl/requests): MEGAMARKET_USER_AGENT=Mozilla/5.0 ...

# Яндекс Маркет Partner API v2: в подключении api_key = Api-Key (или OAuth: тогда задайте client_id).
# store_id = businessId кабинета (целое число), см. документацию GET /v2/campaigns.

# URL сервиса visual_ai (GPU)
VISUAL_AI_SERVICE_URL=http://127.0.0.1:8001

# CORS: через запятую точные Origin из браузера (в проде обычно https://ваш-домен).
# Пусто = встроенный список в main.py (там уже есть https://pim.giper.fm.postobot.online и localhost для разработки).
CORS_ALLOW_ORIGINS=

# Опционально: файл для логов 422 вместо только stderr
VALIDATION_ERROR_LOG_PATH=

# Суффиксы хостов для /api/v1/media/proxy (через запятую). Пусто = встроенный список маркетплейсов.
IMAGE_PROXY_ALLOWED_HOST_SUFFIXES=

# Ключи (только через env, не в коде)
DEEPSEEK_API_KEY=
HUGGINGFACE_HUB_TOKEN=
